{
    "name": "memory-haven-backend",
    "version": "1.0.0",
    "description": "API Backend Memory Haven - Plateforme familiale de souvenirs",
    "main": "src/app.js",
    "scripts": {
        "start": "node src/app.js",
        "build": "prisma generate && prisma db push",
        "start:prod": "prisma db push && node prisma/seed.js && node src/app.js",
        "dev": "nodemon src/app.js",
        "postinstall": "prisma generate",
        "db:push": "prisma db push",
        "db:seed": "node prisma/seed.js",
        "db:setup": "prisma db push && node prisma/seed.js"
    },
    "prisma": {
        "seed": "node prisma/seed.js"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "bcrypt": "^5.1.1",
        "cloudinary": "^1.41.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "multer-storage-cloudinary": "4.0.0",
        "prisma": "^5.22.0",
        "socket.io": "^4.8.1"
    },
    "devDependencies": {
        "nodemon": "^3.1.9"
    }
}
